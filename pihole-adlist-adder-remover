#!/bin/sh
# This script gets its data from https://firebog.net/ which provides various adlists
# to be used by pihole. This script uses the safest lists which most likely
# will not have false positives.

# To make executable by anacron run the following in your terminal
# sudo chmod +x pihole-adlist-adder-remover
# sudo chown root:root pihole-adlist-adder-remover

set -eu

DATABASE_PATH="/etc/pihole/gravity.db"
ADLISTS_HOST="https://v.firebog.net/hosts/lists.php?type=tick"

echo "Requesting adlists from ${ADLISTS_HOST}"

if ! ADLISTS=$(curl -fsS "$ADLISTS_HOST"); then
  echo "Error retrieving adlists from ${ADLISTS_HOST}"
  exit 1
fi

# Sanity check: first line must look like a URL.
FIRST_LINE=$(printf '%s\n' "$ADLISTS" | head -n1)
case "$FIRST_LINE" in
  https://*) ;;
  *)
    echo "Unexpected response from ${ADLISTS_HOST}"
    exit 1
    ;;
esac

# SQL-escape a value by doubling single quotes.
sql_escape() {
  printf '%s' "$1" | sed "s/'/''/g"
}

COMMENT="Migrated from ${ADLISTS_HOST}"
COMMENT_ESC=$(sql_escape "$COMMENT")

# Add missing adlists.
printf '%s\n' "$ADLISTS" | while IFS= read -r ADLIST; do
  [ -z "$ADLIST" ] && continue
  ADLIST_ESC=$(sql_escape "$ADLIST")

  SELECT_RESULT=$(sqlite3 "$DATABASE_PATH" \
    "SELECT 1 FROM adlist WHERE address = '${ADLIST_ESC}';")

  if [ -z "$SELECT_RESULT" ]; then
    echo "Inserting ${ADLIST} into gravity.db adlist table"
    sqlite3 "$DATABASE_PATH" \
      "INSERT INTO adlist (address, comment) VALUES('${ADLIST_ESC}', '${COMMENT_ESC}');"
  else
    echo "${ADLIST} already exists"
  fi
done

# Reconcile enabled/disabled state against current upstream list.
sqlite3 -separator '|' "$DATABASE_PATH" \
  "SELECT address, enabled FROM adlist WHERE comment = '${COMMENT_ESC}';" \
  | while IFS='|' read -r ADDRESS ENABLED; do
    [ -z "${ADDRESS:-}" ] && continue

    EXISTS_ON_ADLISTS_HOST="NO"
    if printf '%s\n' "$ADLISTS" | grep -Fxq "$ADDRESS"; then
      EXISTS_ON_ADLISTS_HOST="YES"
    fi

    ADDRESS_ESC=$(sql_escape "$ADDRESS")

    if [ "$EXISTS_ON_ADLISTS_HOST" != "YES" ] && [ "$ENABLED" = "1" ]; then
      echo "Disabling ${ADDRESS}"
      sqlite3 "$DATABASE_PATH" \
        "UPDATE adlist SET enabled = 0 WHERE address = '${ADDRESS_ESC}';"
    elif [ "$EXISTS_ON_ADLISTS_HOST" = "YES" ] && [ "$ENABLED" = "0" ]; then
      echo "Re-enabling ${ADDRESS}"
      sqlite3 "$DATABASE_PATH" \
        "UPDATE adlist SET enabled = 1 WHERE address = '${ADDRESS_ESC}';"
    fi
  done


